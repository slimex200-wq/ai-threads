# Copy to .env for local runs. Keep real secrets out of git.

# Required for generation.
ANTHROPIC_API_KEY=
THREADS_LLM_BACKEND=claude_cli
CONTENT_MODE=informational

# Required only for direct Threads posting / --publish-approved.
THREADS_ACCESS_TOKEN=
THREADS_USER_ID=

# Optional Telegram preview/result notifications.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Notion review gate.
# When enabled, generated drafts are sent to Notion as Status=Review and direct posting stops.
NOTION_REVIEW_REQUIRED=1
NOTION_CONTENT_DATABASE_ID=e8fb2e0e1aba4736b25000befcb5825e
NOTION_API_KEY=

# Optional media upload fallback.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
